# Demo: piz multi-candidate mode
Output assets/demo-multi.gif

Set Shell "bash"
Set FontSize 18
Set Width 900
Set Height 500
Set Padding 20
Set TypingSpeed 60ms
Set Theme "Catppuccin Mocha"

# Multi-candidate mode
Type "piz -n 3 find large files"
Enter
Sleep 12s

# Press Escape/q to cancel
Type "q"
Sleep 2s

Sleep 2s
